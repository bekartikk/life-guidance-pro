rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          "devilkartik2580@gmail.com"
        ];
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function matchesSignedInEmail() {
      return request.resource.data.userEmail == request.auth.token.email;
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && matchesSignedInEmail();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /plans/{planId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesSignedInEmail();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesSignedInEmail();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /goals/{goalId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesSignedInEmail();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /habits/{habitId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesSignedInEmail();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /weeklyReviews/{reviewId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesSignedInEmail();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /monthlyReviews/{reviewId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesSignedInEmail();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /careerExplorations/{itemId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesSignedInEmail();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /hobbyPlans/{itemId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesSignedInEmail();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /routineBuilders/{itemId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesSignedInEmail();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /reminderSettings/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && matchesSignedInEmail();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /progress/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /progress/{userId}/checkins/{checkinId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /progress/{userId}/events/{eventId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
