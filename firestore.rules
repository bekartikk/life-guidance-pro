rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function hasSignedInEmail() {
      return signedIn() && request.auth.token.email != null;
    }

    function isAdmin() {
      return hasSignedInEmail()
        && request.auth.token.email in [
          "devilkartik2580@gmail.com"
        ];
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function matchesSignedInEmail() {
      return hasSignedInEmail()
        && request.resource.data.userEmail == request.auth.token.email;
    }

    function validOwnedCreate() {
      return signedIn()
        && hasSignedInEmail()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email;
    }

    function ownershipUnchanged() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.userEmail == resource.data.userEmail;
    }

    function ownerCanUpdateOwnedDocument() {
      return isOwner(resource.data.userId)
        && ownershipUnchanged()
        && matchesSignedInEmail();
    }

    function adminCanUpdateOwnedDocument() {
      return isAdmin() && ownershipUnchanged();
    }

    function validOptionalUserId(data, userId) {
      return !data.keys().hasAny(["userId"]) || data.userId == userId;
    }

    function validOptionalUserEmail(data) {
      return !data.keys().hasAny(["userEmail"])
        || (hasSignedInEmail() && data.userEmail == request.auth.token.email);
    }

    function optionalOwnershipValidForPath(userId) {
      return validOptionalUserId(request.resource.data, userId)
        && validOptionalUserEmail(request.resource.data);
    }

    function optionalOwnershipUnchangedForPath(userId) {
      return optionalOwnershipValidForPath(userId)
        && (!resource.data.keys().hasAny(["userId"]) || request.resource.data.userId == resource.data.userId)
        && (!resource.data.keys().hasAny(["userEmail"]) || request.resource.data.userEmail == resource.data.userEmail);
    }

    function ownerCanWritePathDocument(userId) {
      return isOwner(userId) && optionalOwnershipValidForPath(userId);
    }

    function ownerCanUpdatePathDocument(userId) {
      return isOwner(userId) && optionalOwnershipUnchangedForPath(userId);
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && matchesSignedInEmail();
      allow update: if isOwner(userId)
        && matchesSignedInEmail()
        && request.resource.data.userEmail == resource.data.userEmail;
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /plans/{planId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if validOwnedCreate();
      allow update: if ownerCanUpdateOwnedDocument() || adminCanUpdateOwnedDocument();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if validOwnedCreate();
      allow update: if ownerCanUpdateOwnedDocument() || adminCanUpdateOwnedDocument();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /goals/{goalId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if validOwnedCreate();
      allow update: if ownerCanUpdateOwnedDocument() || adminCanUpdateOwnedDocument();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /habits/{habitId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if validOwnedCreate();
      allow update: if ownerCanUpdateOwnedDocument() || adminCanUpdateOwnedDocument();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /weeklyReviews/{reviewId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if validOwnedCreate();
      allow update: if ownerCanUpdateOwnedDocument() || adminCanUpdateOwnedDocument();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /monthlyReviews/{reviewId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if validOwnedCreate();
      allow update: if ownerCanUpdateOwnedDocument() || adminCanUpdateOwnedDocument();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /careerExplorations/{itemId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if validOwnedCreate();
      allow update: if ownerCanUpdateOwnedDocument() || adminCanUpdateOwnedDocument();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /hobbyPlans/{itemId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if validOwnedCreate();
      allow update: if ownerCanUpdateOwnedDocument() || adminCanUpdateOwnedDocument();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /routineBuilders/{itemId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if validOwnedCreate();
      allow update: if ownerCanUpdateOwnedDocument() || adminCanUpdateOwnedDocument();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /reminderSettings/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if ownerCanWritePathDocument(userId) && matchesSignedInEmail();
      allow update: if ownerCanUpdatePathDocument(userId)
        && matchesSignedInEmail()
        && request.resource.data.userEmail == resource.data.userEmail;
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /progress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if ownerCanWritePathDocument(userId);
      allow update: if ownerCanUpdatePathDocument(userId) || (isAdmin() && optionalOwnershipUnchangedForPath(userId));
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /progress/{userId}/checkins/{checkinId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if ownerCanWritePathDocument(userId);
      allow update: if ownerCanUpdatePathDocument(userId) || (isAdmin() && optionalOwnershipUnchangedForPath(userId));
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /progress/{userId}/events/{eventId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if ownerCanWritePathDocument(userId);
      allow update: if ownerCanUpdatePathDocument(userId) || (isAdmin() && optionalOwnershipUnchangedForPath(userId));
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /analytics/{userId}/{document=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if ownerCanWritePathDocument(userId);
      allow update: if ownerCanUpdatePathDocument(userId) || (isAdmin() && optionalOwnershipUnchangedForPath(userId));
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}